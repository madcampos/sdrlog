{
	"name": "sdrlog",
	"private": true,
	"version": "1.0.0",
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=24.13.0",
		"pnpm": ">=10.26.2"
	},
	"scripts": {
		"bootstrap:certs": "mkdir certs && mkcert -key-file=certs/server.key -cert-file=certs/server.crt localhost",
		"start": "vite",
		"typecheck": "tsc --noEmit",
		"lint:js": "oxlint --fix",
		"lint": "pnpm run typecheck && pnpm run lint:js",
		"format": "dprint fmt",
		"build": "vite build",
		"prepreview": "pnpm run build",
		"preview": "vite preview --port 3000",
		"predeploy": "pnpm run build",
		"deploy": "wrangler deploy --minify"
	},
	"dependencies": {
		"@emulatorjs/core-genesis_plus_gx": "^4.2.3",
		"@emulatorjs/core-snes9x": "^4.2.3",
		"@emulatorjs/emulatorjs": "^4.2.3",
		"@lit-labs/router": "^0.1.4",
		"@mad-c/file-system-helpers": "^1.1.0",
		"@squoosh-kit/mozjpeg": "^0.2.4",
		"epubjs": "^0.3.93",
		"iconify-icon": "^3.0.2",
		"idb": "^8.0.3",
		"jszip": "^3.10.1",
		"lit": "^3.3.3",
		"marked": "^18.0.5",
		"nipplejs": "^1.0.4",
		"open-props": "1.7.23",
		"pdfjs-dist": "^6.1.200",
		"valibot": "^1.4.2"
	},
	"devDependencies": {
		"@types/emscripten": "^1.41.5",
		"@types/node": "26.0.1",
		"@types/wicg-file-system-access": "^2023.10.7",
		"@vitest/browser-playwright": "4.1.9",
		"dprint": "^0.55.1",
		"oxlint": "^1.71.0",
		"oxlint-tsgolint": "^0.23.0",
		"typed-query-selector": "^2.12.2",
		"typescript": "^6.0.3",
		"vite": "^8.1.0",
		"vitest": "4.1.9",
		"vitest-browser-lit": "1.0.1",
		"wrangler": "4.105.0"
	},
	"overrides": {
		"has": "npm:@nolyfill/has@^1",
		"string.prototype.matchall": "npm:@nolyfill/string.prototype.matchall@^1",
		"hasown": "npm:@nolyfill/hasown@^1",
		"isarray": "npm:@nolyfill/isarray@^1",
		"is-core-module": "npm:@nolyfill/is-core-module@^1",
		"safe-buffer": "npm:@nolyfill/safe-buffer@^1"
	}
}
